# Public DNS name pointing to the central monitoring host.
MONITOR_DOMAIN=monitor.example.com
ACME_EMAIL=ops@example.com

# Caddy basic auth for remote_write and Alertmanager.
REMOTE_WRITE_USERNAME=agent
# Generate with:
# docker run --rm caddy:2 caddy hash-password --plaintext 'change-me'
# Keep the bcrypt hash quoted, because it contains dollar signs.
REMOTE_WRITE_PASSWORD_HASH='$2a$14$replacewithcaddybcrypthash'

# Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Alertmanager email settings. Example smarthost: smtp.example.com:587
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=monitoring@example.com
SMTP_AUTH_USERNAME=monitoring@example.com
SMTP_AUTH_PASSWORD=change-me
ALERT_EMAIL_TO=ops@example.com
