{
	email {$ACME_EMAIL}
}

{$MONITOR_DOMAIN} {
	encode zstd gzip

	@remote_write path /api/v1/write
	handle @remote_write {
		basic_auth {
			{$REMOTE_WRITE_USERNAME} {$REMOTE_WRITE_PASSWORD_HASH}
		}
		rewrite * /prometheus/api/v1/write
		reverse_proxy prometheus:9090
	}

	@prometheus_health path /-/healthy /-/ready
	handle @prometheus_health {
		basic_auth {
			{$REMOTE_WRITE_USERNAME} {$REMOTE_WRITE_PASSWORD_HASH}
		}
		rewrite * /prometheus{uri}
		reverse_proxy prometheus:9090
	}

	handle /prometheus* {
		basic_auth {
			{$REMOTE_WRITE_USERNAME} {$REMOTE_WRITE_PASSWORD_HASH}
		}
		reverse_proxy prometheus:9090
	}

	handle /alertmanager* {
		basic_auth {
			{$REMOTE_WRITE_USERNAME} {$REMOTE_WRITE_PASSWORD_HASH}
		}
		reverse_proxy alertmanager:9093
	}

	handle {
		reverse_proxy grafana:3000
	}
}
